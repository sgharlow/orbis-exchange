{
  "name": "@orbis/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "bundle": "esbuild src/handler.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/handler.js --external:pg-native --banner:js=\"const __importMetaUrl=require('url').pathToFileURL(__filename).href;\" \"--define:import.meta.url=__importMetaUrl\""
  },
  "dependencies": { "@orbis/db": "workspace:*" },
  "devDependencies": { "esbuild": "^0.24.0", "tsx": "^4.19.0", "typescript": "^5.6.0", "vitest": "^2.1.0" }
}
